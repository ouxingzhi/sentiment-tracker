# 数据库配置
DATABASE_URL=postgresql://sentiment:sentiment123@localhost:5432/sentiment_db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# OpenAI API (情感分析)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# 财经新闻API
NEWS_API_KEY=xxx
FINVIZ_API_KEY=xxx

# 微博 (可选，需要cookie)
WEIBO_COOKIE=

# 雪球 (可选)
XUEQIU_COOKIE=

# Twitter/X (可选)
TWITTER_BEARER_TOKEN=

# Telegram 推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=6086651958

# 监控配置
ALERT_SENTIMENT_THRESHOLD=-0.7
ALERT_VOLUME_MULTIPLIER=3.0
ALERT_KEYWORDS=暴跌,崩盘,爆仓,利空,违约

# 监控股票列表 (逗号分隔)
WATCH_STOCKS=AAPL,NVDA,TSLA,MSFT,GOOGL,贵州茅台,宁德时代,比亚迪

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4